// Synthesized drum voices via WebAudio. Exposes window.DrumAudio.
(function () {
  let ctx = null;
  let master = null;
  let noiseBuf = null;

  // Real acoustic samples (The Open Source Drum Kit, Real Music Media),
  // embedded as base64 MP3 (mono 32kHz). Decoded lazily on first user
  // interaction; the synthesized voices below stay as a fallback until
  // each sample's AudioBuffer is ready (or if decoding fails).
  const SAMPLES = {
    kick: "",
    snare: "",
    hihat: "",
    tom1: "",
    tom2: "",
    floor: "",
    crash: "",
    ride: ""
  };
  const buffers = {};
  let decoding = false;

  // per-piece gain so the recorded samples sit together in the mix
  const SAMPLE_GAIN = { kick: 1.0, snare: 0.9, hihat: 0.55, tom1: 0.85, tom2: 0.85, floor: 0.9, crash: 0.7, ride: 0.6 };

  function b64ToArrayBuffer(b64) {
    const bin = atob(b64);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    return bytes.buffer;
  }

  function decodeAll() {
    if (decoding) return;
    decoding = true;
    Object.entries(SAMPLES).forEach(([id, b64]) => {
      ctx.decodeAudioData(b64ToArrayBuffer(b64),
        (buf) => { buffers[id] = buf; },
        () => {});
    });
  }

  function ensure() {
    if (!ctx) {
      ctx = new (window.AudioContext || window.webkitAudioContext)();
      master = ctx.createGain();
      master.gain.value = 0.9;
      master.connect(ctx.destination);
      // 2s of white noise, reused
      const len = ctx.sampleRate * 2;
      noiseBuf = ctx.createBuffer(1, len, ctx.sampleRate);
      const d = noiseBuf.getChannelData(0);
      for (let i = 0; i < len; i++) d[i] = Math.random() * 2 - 1;
    }
    if (ctx.state === "suspended") ctx.resume();
    decodeAll();
    return ctx;
  }

  function noise() {
    const s = ctx.createBufferSource();
    s.buffer = noiseBuf;
    s.loop = true;
    return s;
  }

  function env(node, t, peak, decay, hold) {
    node.gain.setValueAtTime(0.0001, t);
    node.gain.exponentialRampToValueAtTime(peak, t + 0.002);
    node.gain.exponentialRampToValueAtTime(0.0001, t + 0.002 + decay);
    return t + 0.01 + decay + (hold || 0);
  }

  const voices = {
    kick(t, g) {
      const o = ctx.createOscillator();
      o.type = "sine";
      o.frequency.setValueAtTime(165, t);
      o.frequency.exponentialRampToValueAtTime(46, t + 0.13);
      const ge = ctx.createGain();
      o.connect(ge).connect(g);
      const end = env(ge, t, 1.0, 0.34);
      o.start(t); o.stop(end);
      // beater click
      const n = noise(), hp = ctx.createBiquadFilter(), ng = ctx.createGain();
      hp.type = "highpass"; hp.frequency.value = 3500;
      n.connect(hp).connect(ng).connect(g);
      env(ng, t, 0.35, 0.02);
      n.start(t); n.stop(t + 0.05);
    },
    snare(t, g) {
      const o = ctx.createOscillator();
      o.type = "triangle";
      o.frequency.setValueAtTime(190, t);
      o.frequency.exponentialRampToValueAtTime(130, t + 0.1);
      const og = ctx.createGain();
      o.connect(og).connect(g);
      const e1 = env(og, t, 0.45, 0.12);
      o.start(t); o.stop(e1);
      const n = noise(), hp = ctx.createBiquadFilter(), ng = ctx.createGain();
      hp.type = "highpass"; hp.frequency.value = 1700;
      n.connect(hp).connect(ng).connect(g);
      env(ng, t, 0.85, 0.18);
      n.start(t); n.stop(t + 0.25);
    },
    hihat(t, g, open) {
      const n = noise(), hp = ctx.createBiquadFilter(), ng = ctx.createGain();
      hp.type = "highpass"; hp.frequency.value = 8000;
      n.connect(hp).connect(ng).connect(g);
      env(ng, t, 0.5, open ? 0.32 : 0.045);
      n.start(t); n.stop(t + (open ? 0.4 : 0.08));
    },
    tom(t, g, freq) {
      const o = ctx.createOscillator();
      o.type = "sine";
      o.frequency.setValueAtTime(freq * 1.6, t);
      o.frequency.exponentialRampToValueAtTime(freq, t + 0.18);
      const ge = ctx.createGain();
      o.connect(ge).connect(g);
      const end = env(ge, t, 0.9, 0.42);
      o.start(t); o.stop(end);
    },
    crash(t, g) {
      const n = noise(), hp = ctx.createBiquadFilter(), bp = ctx.createBiquadFilter(), ng = ctx.createGain();
      hp.type = "highpass"; hp.frequency.value = 5000;
      bp.type = "bandpass"; bp.frequency.value = 9000; bp.Q.value = 0.6;
      n.connect(hp).connect(bp).connect(ng).connect(g);
      ng.gain.setValueAtTime(0.0001, t);
      ng.gain.exponentialRampToValueAtTime(0.5, t + 0.01);
      ng.gain.exponentialRampToValueAtTime(0.0001, t + 1.3);
      n.start(t); n.stop(t + 1.4);
    },
    ride(t, g) {
      const n = noise(), hp = ctx.createBiquadFilter(), ng = ctx.createGain();
      hp.type = "highpass"; hp.frequency.value = 8500;
      n.connect(hp).connect(ng).connect(g);
      env(ng, t, 0.28, 0.5);
      n.start(t); n.stop(t + 0.6);
      // bell tone
      [840, 1260].forEach((f) => {
        const o = ctx.createOscillator(), og = ctx.createGain();
        o.type = "square"; o.frequency.value = f;
        o.connect(og).connect(g);
        env(og, t, 0.06, 0.5);
        o.start(t); o.stop(t + 0.55);
      });
    },
  };

  const route = {
    kick: (t, g) => voices.kick(t, g),
    snare: (t, g) => voices.snare(t, g),
    hihat: (t, g) => voices.hihat(t, g, false),
    tom1: (t, g) => voices.tom(t, g, 210),
    tom2: (t, g) => voices.tom(t, g, 155),
    floor: (t, g) => voices.tom(t, g, 100),
    crash: (t, g) => voices.crash(t, g),
    ride: (t, g) => voices.ride(t, g),
  };

  window.DrumAudio = {
    resume() { ensure(); },
    play(id, when) {
      ensure();
      const t = when || ctx.currentTime;
      const buf = buffers[id];
      if (buf) {
        const s = ctx.createBufferSource();
        s.buffer = buf;
        const g = ctx.createGain();
        g.gain.value = SAMPLE_GAIN[id] ?? 0.8;
        s.connect(g).connect(master);
        s.start(t);
      } else {
        (route[id] || route.snare)(t, master);
      }
    },
    loaded() { return Object.keys(buffers).length; },
    now() { return ctx ? ctx.currentTime : 0; },
    setVolume(v) { if (master) master.gain.value = v; },
  };
})();
